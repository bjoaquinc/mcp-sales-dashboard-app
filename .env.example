# Required: AuthKit subdomain (WorkOS Dashboard -> Domains -> AuthKit Domain)
# The subdomain is the part before .authkit.app (e.g., "my-company" from "my-company.authkit.app")
MCP_USE_OAUTH_WORKOS_SUBDOMAIN=vocal-science-44-staging.authkit.app

# Optional: Pre-registered OAuth client ID (omit for DCR mode, recommended for MCP Inspector)
# MCP_USE_OAUTH_WORKOS_CLIENT_ID=client_01KB5DRXBDDY1VGCBKY108SKJW

# Optional: WorkOS API key for management API calls
# MCP_USE_OAUTH_WORKOS_API_KEY=sk_test_...
